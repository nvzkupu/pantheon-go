# OpenAI-compatible gateway URL
GATEWAY_URL=https://integrate.api.nvidia.com/v1

# API key or bearer token
API_KEY=

# Override skills directory (default: .agents/skills)
# SKILLS_DIR=.agents/skills

# Session memory directory (default: .memory)
# MEMORY_DIR=.memory

# Verbose logging: tool calls, token counts (set to 1)
# VERBOSE=1
